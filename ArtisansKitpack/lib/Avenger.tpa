
COPY ~%MOD_FOLDER%/Druid/Avenger/2DAs~ ~OVERRIDE~
COPY ~%MOD_FOLDER%/Druid/Avenger/SPELLS~ ~OVERRIDE~

OUTER_SPRINT kit_description ~AVENGER: A member of a special sect within the druidic order, a Druid of this type is dedicated to fighting those who would defile nature. Avengers have powers the average Druid does not—additional abilities that have been earned through extensive rituals, a process that is very physically draining.

Advantages:
– +1 bonus to Wisdom.KIT_ADV_1
– Nature's Renewal: The avenger, when under the effects of Barkskin, Stoneskin or Iron Skins, regenerates for 12% of their maximum hit points every round.
– 3rd level: May select one of three Pacts of Nature, each providing permanent bonuses and penalties. Each pact may only be selected once.

PACT OF NATURE'S FURY: The avenger's attacks deal one additional unmitigated piercing damage to unnatural creatures such as undead, outsiders and abberations.
   The damage bonus increases to two at 9th level and three at 15th level.
   The avenger loses four points of Dexterity after selecting this Pact.

PACT OF NATURE'S SECRETS: The avenger gains the use of certain arcane spells, and a +1 bonus to casting speed.
   1st level: Chromatic Orb, Spook
   2nd level: Invisibility, Horror
   3rd level: Slow, Vampiric Touch
   4th level: Improved Invisibility, Polymorph Self
   5th level: Chaos, Lower Resistance
   6th level: Flesh to Stone, Wyvern Call
   7th level: Mass Invisibility, Sphere of Chaos
   The casting speed bonus increases to +2 at 9th level and +3 at 15th level.
   The avenger loses four points of Strength after selecting this Pact.

PACT OF NATURE'S HARVEST: The avenger gains a x2 backstab multiplier. Additionally, backstabs made by the avenger entangle the target for up to three rounds. At the end of each round, the target will lose 5% of their current hit points and their resistances, including Magic Resistance, which are transferred to the avenger for one turn. The target may not make a Saving Throw for the first round of entanglement, but may make a Saving Throw vs. Spells at -3 and -1 respectively for the following two rounds to break free and resist the draining effect.
   The avenger's backstab multiplier increases to x3 at 9th level and x4 at 15th level.
   The avenger loses four points of Constitution after selecting this Pact.

– 7th level: May Wild Shape into the form of a winter wolf, baby wyvern, and fire salamander in addition to the normal shapeshifting abilities.
– 8th level: Nature's Renewal now regenerates for 18% maximum hit points per round.
– 9th level: May select another Pact of Nature.
– 14th level: Nature's Renewal now regenerates for 24% maximum hit points per round.
– 15th level: May select another Pact of Nature.
– 19th level: Gains an additional use of Shapeshift.

Disadvantages:
– May not wear heavier armor than leather.
– Upon selecting any Pact of Nature, the avenger permanently loses the ability to receive direct healing from most sources, with certain exceptions such as healing from damage dealt, regeneration, and Nature's Renewal.~

ACTION_IF (MOD_IS_INSTALLED ~EEEX/EEEX.TP2~ ~0~) THEN BEGIN

OUTER_PATCH_SAVE kit_description ~%kit_description%~ BEGIN
  REPLACE_TEXTUALLY ~KIT_ADV_1~ ~
– Camouflage: The avenger gains a 25% bonus to Hide in Shadows and Move Silently while outdoors.
– May use Hide in Shadows.~

END

END ELSE BEGIN

OUTER_PATCH_SAVE kit_description ~%kit_description%~ BEGIN
  REPLACE_TEXTUALLY ~KIT_ADV_1~ ~~
END

END

LAF ~GET_KIT_STRREF~ STR_VAR kit_name = ~BEAST_FRIEND~ RET kit_strref END
STRING_SET_EVALUATE kit_strref ~%kit_description%~
	
COPY_EXISTING ~abclsmod.2da~ ~override~
	COUNT_2DA_COLS cols // amount of columns
	READ_2DA_ENTRIES_NOW rows cols // read all file into memory  
	FOR (row = 1; row < rows; ++row) BEGIN // iterate over rows
	  READ_2DA_ENTRY_FORMER rows row 0 ~text~ // read column value
	  PATCH_IF ~%text%~ STRING_EQUAL_CASE ~BEAST_FRIEND~ BEGIN
	    SET patch_row = %row%
		SET_2DA_ENTRY (%patch_row%) 5 cols %-2%
	  END
	END

// STONESKINS
APPEND ~splprot.2da~ ~C0_STONESKIN_GT 88 -1 3~ UNLESS ~C0_STONESKIN_GT~
COPY_EXISTING ~splprot.2da~ ~override~
	COUNT_2DA_COLS cols // amount of columns
	READ_2DA_ENTRIES_NOW rows cols // read all file into memory  
	FOR (row = 1; row < rows; ++row) BEGIN // iterate over rows
	  READ_2DA_ENTRY_FORMER rows row 0 ~stat~ // read column value
	  PATCH_IF ~%stat%~ STRING_EQUAL_CASE ~C0_STONESKIN_GT~ BEGIN
	    SET C0_STONESKIN_GT = %row%
	  END
	END
	
// Resistances

ACTION_DEFINE_ASSOCIATIVE_ARRAY	DMG_ARRAY_SPECIFIC	BEGIN
	~CRUSH~		=>	22
	~ACID~		=>	17
	~COLD~		=>	15
	~ELEC~		=>	16
	~FIRE~		=>	14
	~PIERC~		=>	23
	~POISN~		=>	74
	~MAGIC~		=>	73
	~MSSL~		=>	24
	~SLASH~		=>	21
	~MFIRE~		=>	19
	~MCOLD~		=>	20
	~MRES~		=>	18
END
ACTION_PHP_EACH	DMG_ARRAY_SPECIFIC AS one => two	BEGIN
APPEND ~splprot.2da~ ~C0_%one%_EQUALS %two% -1 1~ UNLESS ~C0_%one%_EQUALS~
COPY_EXISTING ~splprot.2da~ ~override~
	COUNT_2DA_COLS cols // amount of columns
	READ_2DA_ENTRIES_NOW rows cols // read all file into memory  
	FOR (row = 1; row < rows; ++row) BEGIN // iterate over rows
	  READ_2DA_ENTRY_FORMER rows row 0 ~stat~ // read column value
	  PATCH_IF ~%stat%~ STRING_EQUAL_CASE ~C0_%one%_EQUALS~ BEGIN
	    SET "C0_%one%_EQUALS" = %row%
	  END
	END
END

ACTION_DEFINE_ASSOCIATIVE_ARRAY	DMG_ARRAY_GT	BEGIN
	~CRUSH~		=>	22
	~ACID~		=>	17
	~COLD~		=>	15
	~ELEC~		=>	16
	~FIRE~		=>	14
	~PIERC~		=>	23
