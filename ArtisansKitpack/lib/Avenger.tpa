LPF ALTER_EFFECT INT_VAR match_opcode = 326 match_parameter2 = 0 parameter2 = C0_STONESKIN_GT END

ACTION_FOR_EACH healing_spell IN dw#fpplo SPIN101 SPIN200 SPIN958 SPPR103 SPPR217 SPPR315 SPPR317 SPPR401 SPPR502 SPPR514 BHAAL1A DEVAHEAL SENSPIHE SPIN679 SPIN699 SPIN711 SPPR607 SPCL211 SPCL815 SPIN200 C0APOT01 C0ARUNE8 C0TRBS1 C0TRBS3 C0TRBS4 C0TRBS5 FINP101 POTN08 POTN55 POTN52 BRAC20 BEGIN
COPY_EXISTING ~C0D4_8.SPL~ ~OVERRIDE~
LPF ADD_SPELL_EFFECT INT_VAR opcode = 324 target = 2 timing = 9 STR_VAR resource = EVAL ~%healing_spell%~ END
END

