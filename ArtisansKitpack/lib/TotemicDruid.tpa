COPY_EXISTING ~luabbr.2da~ ~override~
	COUNT_2DA_COLS cols // amount of columns
	READ_2DA_ENTRIES_NOW rows cols // read all file into memory  
	FOR (row = 1; row < rows; ++row) BEGIN // iterate over rows
	  READ_2DA_ENTRY_FORMER rows row 0 ~text~ // read column value
	  PATCH_IF ~%text%~ STRING_EQUAL_CASE ~TOTEMIC_DRUID~ BEGIN
	    SET patch_row = %row%
		SET_2DA_ENTRY (%patch_row%) 1 cols ~C0D2_~
	  END
	END
COPY_EXISTING ~LUDR0.2da~ ~override/LUC0D2_.2DA~
LPF patch_remove_hla STR_VAR remove_ability = ~GA_SPPR731~ END
LPF patch_remove_hla STR_VAR remove_ability = ~GA_SPPR732~ END
LPF patch_add_hla STR_VAR 2da_row = ~LUC0D2_1~ ability = ~AP_C0D2_H1~ num_allowed = 1 END	
LPF patch_add_hla STR_VAR 2da_row = ~LUC0D2_2~ ability = ~AP_C0D2_H2~ num_allowed = 1 END	

COPY_EXISTING ~C0D2_H1.SPL~ ~OVERRIDE~
SAY NAME1 ~Empower Spirit: Might~
SAY UNIDENTIFIED_DESC ~After selecting this ability, the totemic druid's spirit animal gains the ability to use the abilities Greater Whirlwind, Power Attack and Critical Strike once per manifestation.~

COPY_EXISTING ~C0D2_H2.SPL~ ~OVERRIDE~
SAY NAME1 ~Empower Spirit: Fortitude~
SAY UNIDENTIFIED_DESC ~After selecting this ability, the totemic druid's spirit animal gains the ability to use the abilities Hardiness, Resist Magic and Greater Evasion once per manifestation.~